#!/usr/bin/env python3
"""nsync-gui — TUI password manager with live search and pending approvals."""
import curses
import json
import os
import subprocess
import sys
import time

CONFIG_FILE = os.path.expanduser("~/.config/nsync/config.json")
_totp_code = None  # cached TOTP for the session


def _needs_totp():
    """Check if refresh token is likely expired (untrusted device, >1h)."""
    try:
        with open(CONFIG_FILE) as f:
            cfg = json.load(f)
        if cfg.get("trusted"):
            return False
        ts = cfg.get("auth_timestamp", 0)
        return (time.time() - ts) > 3600
    except Exception:
        return False


def nsync(args, input_text=None):
    global _totp_code
    # If auth is needed and we have a cached TOTP, pass it via stdin
    if input_text is None and _totp_code:
        input_text = _totp_code
    try:
        p = subprocess.run(["nsync"] + args, capture_output=True, text=True, input=input_text, timeout=30)
        return p.stdout, p.stderr, p.returncode
    except Exception as e:
        return "", str(e), 1

def get_entries():
    out, _, rc = nsync(["ls"])
    return [l.strip() for l in out.strip().split("\n") if l.strip()] if rc == 0 else []

def add_entry(path, value):
    """Add entry — value goes via stdin."""
    out, err, rc = nsync(["add", path], input_text=value)
    return rc == 0, (out + err).strip()

def get_pending():
    """Get pending approvals by feeding 'q' to quit."""
    p = subprocess.Popen(["nsync", "approve"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
    try:
        out, _ = p.communicate(input="q\n", timeout=10)
    except:
        p.kill()
        return []
    if "No pending" in out:
        return []
    # Parse pending items
    pending = []
    lines = out.split("\n")
    current = {}
    for line in lines:
        if "--- Pending from" in line:
            if current:
                pending.append(current)
            current = {"source": line.split("from")[1].split("at")[0].strip()}
        elif "Action:" in line:
            current["action"] = line.split(":")[1].strip()
        elif "Path:" in line:
            current["path"] = line.split(":", 1)[1].strip()
        elif "New:" in line:
            current["value"] = line.split(":", 1)[1].strip()
    if current and "path" in current:
        pending.append(current)
    return pending


class TUI:
    def __init__(self, stdscr):
        self.scr = stdscr
        self.entries = []
        self.pending = []
        self.filtered = []
        self.sel = 0
        self.search = ""
        self.mode = "list"
        self.msg = ""
        self.view_val = ""
        curses.curs_set(0)
        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(1, curses.COLOR_GREEN, -1)
        curses.init_pair(2, curses.COLOR_YELLOW, -1)
        curses.init_pair(3, curses.COLOR_RED, -1)
        curses.init_pair(4, curses.COLOR_CYAN, -1)
        curses.init_pair(5, curses.COLOR_MAGENTA, -1)

    def prompt_totp(self):
        """Prompt for TOTP code within the TUI."""
        global _totp_code
        h, w = self.scr.getmaxyx()
        self.scr.clear()
        self.scr.addstr(h // 2 - 1, 2, "Session expired — TOTP required", curses.A_BOLD | curses.color_pair(2))
        self.scr.addstr(h // 2, 2, "TOTP code: ")
        self.scr.refresh()
        curses.echo()
        curses.curs_set(1)
        code = self.scr.getstr(h // 2, 13, 10).decode().strip()
        curses.noecho()
        curses.curs_set(0)
        if code:
            _totp_code = code

    def load(self):
        global _totp_code
        if _totp_code is None and _needs_totp():
            self.prompt_totp()
        self.msg = "Loading..."
        self.draw()
        self.entries = get_entries()
        if not self.entries and _totp_code:
            # TOTP may have been wrong or already consumed; clear for retry next time
            _totp_code = None
        self.pending = get_pending()
        self.msg = f"{len(self.entries)} entries" + (f" | {len(self.pending)} pending!" if self.pending else "")
        self.do_filter()

    def do_filter(self):
        if self.search:
            terms = self.search.lower().split()
            self.filtered = [e for e in self.entries if all(t in e.lower() for t in terms)]
        else:
            self.filtered = self.entries
        self.sel = min(self.sel, max(0, len(self.filtered) - 1))

    def draw(self):
        self.scr.clear()
        h, w = self.scr.getmaxyx()

        # Header
        title = " nsync "
        self.scr.addstr(0, 0, "─" * w, curses.color_pair(4))
        self.scr.addstr(0, (w - len(title)) // 2, title, curses.A_BOLD | curses.color_pair(4))

        if self.mode == "view":
            self._draw_view(h, w)
        elif self.mode == "approve":
            self._draw_approve(h, w)
        else:
            self._draw_list(h, w)

        # Message bar
        if self.msg:
            self.scr.addstr(h-1, 0, f" {self.msg}"[:w-1], curses.color_pair(2))
        self.scr.refresh()

    def _draw_list(self, h, w):
        # Search bar (always visible)
        search_display = self.search if self.search else ""
        self.scr.addstr(1, 0, " 🔍 ", curses.color_pair(2))
        self.scr.addstr(1, 4, search_display[:w-5] if search_display else "type to search...",
                       curses.A_NORMAL if search_display else curses.A_DIM)

        row = 2
        # Pending section (if any)
        if self.pending and not self.search:
            self.scr.addstr(row, 0, f" ⚠ PENDING APPROVAL ({len(self.pending)})", curses.A_BOLD | curses.color_pair(3))
            row += 1
            for p in self.pending[:3]:
                self.scr.addstr(row, 2, f"  {p.get('action','?')} {p.get('path','?')}"[:w-3], curses.color_pair(3))
                row += 1
            self.scr.addstr(row, 2, "  Press [A] to approve", curses.A_DIM)
            row += 2

        # Entry list
        visible = h - row - 2
        start = max(0, self.sel - visible + 3)
        count_str = f" [{len(self.filtered)}/{len(self.entries)}]"
        self.scr.addstr(row, 0, f" Entries{count_str}", curses.A_DIM)
        row += 1

        for i, entry in enumerate(self.filtered[start:start+visible]):
            if row >= h - 2:
                break
            idx = start + i
            if idx == self.sel:
                self.scr.addstr(row, 0, f" ▸ {entry}"[:w-1], curses.A_BOLD | curses.color_pair(1))
            else:
                self.scr.addstr(row, 0, f"   {entry}"[:w-1])
            row += 1

        # Footer
        self.scr.addstr(h-2, 0, " ↑↓/jk:nav  Enter:view  a:add  d:del  A:approve  p:pull  q:quit"[:w-1], curses.A_DIM)

    def _draw_view(self, h, w):
        path = self.filtered[self.sel] if self.filtered else ""
        self.scr.addstr(2, 0, f" {path}", curses.A_BOLD)
        self.scr.addstr(3, 0, "─" * min(w, 50), curses.A_DIM)
        lines = self.view_val.split("\n")
        for i, line in enumerate(lines[:h-7]):
            self.scr.addstr(4 + i, 2, line[:w-3], curses.color_pair(1))
        self.scr.addstr(h-2, 0, " [c]opy  [Esc/b]ack  [q]uit"[:w-1], curses.A_DIM)

    def _draw_approve(self, h, w):
        self.scr.addstr(2, 0, " Pending Approvals", curses.A_BOLD | curses.color_pair(3))
        self.scr.addstr(3, 0, "─" * min(w, 50), curses.A_DIM)
        row = 4
        for i, p in enumerate(self.pending):
            if row >= h - 4:
                break
            marker = "▸" if i == self.sel else " "
            self.scr.addstr(row, 0, f" {marker} [{p.get('action','?')}] {p.get('path','')}"[:w-1],
                           curses.A_BOLD if i == self.sel else curses.A_NORMAL)
            if p.get("value"):
                row += 1
                self.scr.addstr(row, 4, f"→ {p['value']}"[:w-5], curses.color_pair(2))
            row += 1
            self.scr.addstr(row, 4, f"from: {p.get('source','?')}"[:w-5], curses.A_DIM)
            row += 1
        self.scr.addstr(h-2, 0, " [y]approve all  [Esc]back  [q]uit"[:w-1], curses.A_DIM)

    def copy_to_clipboard(self, text):
        for cmd in [["xclip", "-selection", "clipboard"], ["pbcopy"]]:
            try:
                subprocess.run(cmd, input=text.encode(), check=True)
                return True
            except:
                continue
        return False

    def run(self):
        self.load()
        while True:
            self.draw()
            key = self.scr.getch()

            if self.mode == "view":
                if key in (27, ord("b")):
                    self.mode = "list"
                elif key == ord("c"):
                    self.msg = "Copied!" if self.copy_to_clipboard(self.view_val) else "Copy failed"
                elif key == ord("q"):
                    break
            elif self.mode == "approve":
                if key == 27:
                    self.mode = "list"
                    self.sel = 0
                elif key == ord("y"):
                    self.msg = "Approving..."
                    self.draw()
                    p = subprocess.Popen(["nsync", "approve"], stdin=subprocess.PIPE, stdout=subprocess.PIPE, text=True)
                    try:
                        out, _ = p.communicate(input="y\n" * 50, timeout=30)
                        self.msg = "Approved!"
                    except:
                        p.kill()
                        self.msg = "Error approving"
                    self.mode = "list"
                    self.sel = 0
                    self.load()
                elif key == ord("q"):
                    break
            else:
                # List mode
                if key == ord("q"):
                    break
                elif key == 27:  # Esc - clear search
                    self.search = ""
                    self.do_filter()
                elif key in (curses.KEY_UP, ord("k")):
                    self.sel = max(0, self.sel - 1)
                elif key in (curses.KEY_DOWN, ord("j")):
                    self.sel = min(len(self.filtered) - 1, self.sel + 1)
                elif key == curses.KEY_BACKSPACE or key == 127:
                    self.search = self.search[:-1]
                    self.do_filter()
                elif key == 10:  # Enter
                    if self.filtered:
                        self.msg = "Loading..."
                        self.draw()
                        out, err, rc = nsync(["get", self.filtered[self.sel]])
                        self.view_val = out.strip() if rc == 0 else f"Error: {err}"
                        self.mode = "view"
                        if rc == 0:
                            self.copy_to_clipboard(self.view_val.split("\n")[0])
                            self.msg = "Copied to clipboard!"
                        else:
                            self.msg = ""
                elif key == ord("A"):
                    if self.pending:
                        self.mode = "approve"
                        self.sel = 0
                    else:
                        self.msg = "No pending approvals"
                elif key == ord("a"):
                    curses.echo()
                    curses.curs_set(1)
                    h, w = self.scr.getmaxyx()
                    self.scr.addstr(h-3, 0, " Path: " + " " * (w-8))
                    self.scr.refresh()
                    path = self.scr.getstr(h-3, 7, w-8).decode().strip()
                    if path:
                        self.scr.addstr(h-2, 0, " Value: " + " " * (w-9))
                        self.scr.refresh()
                        val = self.scr.getstr(h-2, 8, w-9).decode().strip()
                        if val:
                            ok, msg = add_entry(path, val)
                            self.msg = "Added!" if ok else f"Error: {msg}"
                            self.load()
                    curses.noecho()
                    curses.curs_set(0)
                elif key == ord("d"):
                    if self.filtered:
                        self.msg = f"Delete '{self.filtered[self.sel]}'? [y/N]"
                        self.draw()
                        if self.scr.getch() == ord("y"):
                            nsync(["rm", self.filtered[self.sel]])
                            self.msg = "Deleted"
                            self.load()
                        else:
                            self.msg = ""
                elif key == ord("p"):
                    self.msg = "Pulling..."
                    self.draw()
                    out, _, _ = nsync(["pull"])
                    self.msg = out.strip()[:60]
                    self.load()
                elif 32 <= key <= 126:  # Printable char - live search
                    self.search += chr(key)
                    self.sel = 0
                    self.do_filter()


if __name__ == "__main__":
    curses.wrapper(lambda s: TUI(s).run())
